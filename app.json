{
  "expo": {
    "name": "astra-ar-prototype",
    "slug": "astra-ar-prototype",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "infoPlist": {
        "NSCameraUsageDescription": "This prototype uses the camera to capture live frames and send them to Gemini for scene annotations."
      },
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "CAMERA"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "b112c383-1993-4944-93ae-6a2882ff8c0c"
      }
    },
    "owner": "pavanrao",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/b112c383-1993-4944-93ae-6a2882ff8c0c"
    }
  }
}
